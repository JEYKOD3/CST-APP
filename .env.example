# Copy to .env.local for local dev. Add same vars in Vercel → Settings → Environment Variables.

# Neon (use dev branch for preview/local, main for production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Clerk — https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk URLs (defaults work for local)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
